# ── Track 2 — Consumer Checkout ─────────────────────────────────────────────
# Copy to .env and fill in. Devnet only. The human's Phantom wallet signs —
# there is no buyer keypair here.

# Seller's devnet wallet pubkey (receives the one-click payment)
SELLER_WALLET=

# Helius API key — devnet RPC + WebSocket for watchReference confirmation
HELIUS_API_KEY=

# Price per checkout
PRICE_SOL=0.00005

# RPC (blank = derive from HELIUS_API_KEY, else public devnet)
SOLANA_RPC_URL=https://api.devnet.solana.com

# The browser points Phantom at this RPC for signing/confirming.
# Optional: a Helius devnet RPC URL the front-end can use directly.
NEXT_PUBLIC_HELIUS_RPC=https://api.devnet.solana.com
