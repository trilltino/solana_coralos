# ── Track 1 — Pay-Per-Call API ──────────────────────────────────────────────
# Copy to .env and fill in. Devnet only — never use a funded mainnet keypair.

# ── Required ────────────────────────────────────────────────────────────────
# Seller's devnet wallet pubkey (receives payment)
WALLET=

# Buyer's devnet keypair, base58-encoded.
# Generate: solana-keygen new --no-bip39-passphrase  (then base58-encode the 64-byte secret)
BUYER_KEYPAIR_B58=

# Anthropic key for the LLM buyer's reasoning loop (Claude Haiku)
ANTHROPIC_API_KEY=

# Helius API key (devnet RPC + WebSocket for watchReference confirmation)
HELIUS_API_KEY=

# ── Pricing & service ───────────────────────────────────────────────────────
PRICE_SOL=0.0001
BUYER_MAX_SOL=0.001
SERVICE=jupiter                 # jupiter | coingecko | news  (fork point: seller/src/service.ts)

# ── RPC (blank = derive from HELIUS_API_KEY, else public devnet) ─────────────
SOLANA_RPC_URL=https://api.devnet.solana.com

# ── Optional per-service keys ───────────────────────────────────────────────
JUPITER_API_KEY=                # higher rate limits — free at jup.ag/developers
NEWS_API_KEY=                   # only if SERVICE=news (newsapi.org free tier)
